+def _sanitize_anthropic_empty_text_blocks(messages: List[Dict]) -> None:
+    """Remove or fix empty text content blocks so Anthropic API does not reject the request."""
+    if not messages:
+        return
+    for msg in messages:
+        content = msg.get("content")
+        if content is None:
+            continue
+        if isinstance(content, str):
+            if not content.strip():
+                msg["content"] = " "
+            continue
+        if isinstance(content, list):
+            i = 0
+            while i < len(content):
+                block = content[i]
+                if isinstance(block, dict) and block.get("type") == "text":
+                    text = block.get("text")
+                    if text is None or (isinstance(text, str) and not text.strip()):
+                        content.pop(i)
+                        continue
+                i += 1
+            if not content:
+                msg["content"] = " "
